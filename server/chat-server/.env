# ============================================================
# Chat Server — Environment Variables
# Port 8002 — Socket.IO v2, TEA verification ENABLED
# ============================================================

# Server
CHAT_PORT=8002
CHAT_HOST=0.0.0.0

# Database — shared DB: super_warrior_z
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_DATABASE=super_warrior_z
DB_CONNECTION_LIMIT=5

# Time offset (ms) — HAR verified: +25200000 = UTC+7 (Jakarta)
SERVER_UTC_OFFSET_MS=25200000

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=info
